    {
      "name": "04 Loans",
      "description": "## Folder Loans\n`STATUS: PRODUCTION`\n\nEndpoint peminjaman. Request ini membutuhkan session login aktif. Admin melihat semua data, user hanya melihat miliknya sendiri.",
      "item": [
        {
          "name": "Get Loans",
          "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{api_url}}/loans" },
          "response": [
            { "name": "200 OK", "status": "OK", "code": 200, "_postman_previewlanguage": "json", "body": "{\n  \"current_page\": 1,\n  \"data\": [],\n  \"per_page\": 15,\n  \"total\": 0\n}" },
            { "name": "401 Unauthorized", "status": "Unauthorized", "code": 401, "_postman_previewlanguage": "json", "body": "{\n  \"message\": \"Unauthenticated\"\n}" }
          ]
        },
        {
          "name": "Create Loan",
          "request": {
