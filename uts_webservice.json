          "response": [
            { "name": "200 OK", "status": "OK", "code": 200, "_postman_previewlanguage": "json", "body": "{\n  \"id\": 1,\n  \"status\": \"returned\",\n  \"returned_at\": \"2026-05-01\"\n}" }
          ]
