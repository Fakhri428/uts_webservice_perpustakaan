          "response": [
            { "name": "200 OK", "status": "OK", "code": 200, "_postman_previewlanguage": "json", "body": "{\n  \"id\": 1,\n  \"book_id\": 1,\n  \"user_id\": 2,\n  \"status\": \"borrowed\",\n  \"book\": {\n    \"id\": 1,\n    \"title\": \"Est eos quia est.\"\n  },\n  \"user\": {\n    \"id\": 2,\n    \"name\": \"Regular User\"\n  }\n}" },
